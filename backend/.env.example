# Disaster DSS API Environment Variables

# Application
APP_NAME="Disaster DSS API"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY="your-secret-key-change-in-production"

# Database
DATABASE_URL="postgresql+asyncpg://dss_user:dss_password@localhost:5432/disaster_dss"
DATABASE_URL_SYNC="postgresql://dss_user:dss_password@localhost:5432/disaster_dss"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Kafka
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_TOPIC_PREFIX="disaster_dss"

# AI Model Paths
MODEL_PATH="./models/weights"
YOLO_MODEL_PATH="./models/weights/yolov8-disaster.pt"
BERT_MODEL_PATH="./models/weights/bert-emergency"

# External APIs (optional)
SATELLITE_API_KEY=""
SOCIAL_MEDIA_API_KEY=""

# File Upload
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR="./uploads"

# CORS
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
